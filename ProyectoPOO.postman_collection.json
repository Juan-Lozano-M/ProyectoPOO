{
  "info": {
    "_postman_id": "4f2c5e28-0c72-4b2b-9c9f-9a82e6cb4ad1",
    "name": "ProyectoPOO API - Entrega 2",
    "description": "Coleccion actualizada con seguridad por token + API key, gestion de personas/usuarios y consultas publicas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "apiKey", "value": "" },
    { "key": "adminLogin", "value": "" },
    { "key": "adminPassword", "value": "" },
    { "key": "personId", "value": "1" },
    { "key": "driverPersonId", "value": "1" },
    { "key": "documentId", "value": "1" },
    { "key": "vehicleId", "value": "1" },
    { "key": "plate", "value": "ABC123" },
    { "key": "vehicleType", "value": "AUTOMOVIL" },
    { "key": "documentCode", "value": "SOAT" },
    { "key": "documentState", "value": "EN_VERIFICACION" }
  ],
  "item": [
    {
      "name": "01 - Auth (Publico)",
      "item": [
        {
          "name": "POST Login administrativo",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{adminLogin}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "if (data && data.token) { pm.collectionVariables.set('token', String(data.token)); }",
                  "if (data && data.apiKey) { pm.collectionVariables.set('apiKey', String(data.apiKey)); }",
                  "if (data && data.login) { pm.collectionVariables.set('adminLogin', String(data.login)); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Personas (Protegido)",
      "item": [
        {
          "name": "POST Crear persona ADMIN (genera usuario)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-API-KEY", "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identification\": \"1012345678\",\n  \"identificationType\": \"CC\",\n  \"names\": \"Carlos\",\n  \"lastNames\": \"Perez\",\n  \"email\": \"carlos.perez.admin@example.com\",\n  \"personType\": \"A\"\n}"
            },
            "url": "{{baseUrl}}/api/persons"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "var data = pm.response.json();",
                  "if (data && data.id) { pm.collectionVariables.set('personId', String(data.id)); }",
                  "if (data && data.adminUserData && data.adminUserData.login) { pm.collectionVariables.set('adminLogin', String(data.adminUserData.login)); }",
                  "if (data && data.adminUserData && data.adminUserData.generatedPassword) { pm.collectionVariables.set('adminPassword', String(data.adminUserData.generatedPassword)); }",
                  "if (data && data.adminUserData && data.adminUserData.apiKey) { pm.collectionVariables.set('apiKey', String(data.adminUserData.apiKey)); }"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Crear persona CONDUCTOR",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-API-KEY", "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identification\": \"1022334455\",\n  \"identificationType\": \"CC\",\n  \"names\": \"Ana\",\n  \"lastNames\": \"Gomez\",\n  \"email\": \"ana.gomez.driver@example.com\",\n  \"personType\": \"C\"\n}"
            },
            "url": "{{baseUrl}}/api/persons"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "var data = pm.response.json();",
                  "if (data && data.id) { pm.collectionVariables.set('driverPersonId', String(data.id)); }"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Listar personas",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-API-KEY", "value": "{{apiKey}}" }
            ],
            "url": "{{baseUrl}}/api/persons"
          }
        },
        {
          "name": "GET Persona por ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-API-KEY", "value": "{{apiKey}}" }
            ],
            "url": "{{baseUrl}}/api/persons/{{personId}}"
          }
        },
        {
          "name": "PUT Actualizar persona",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-API-KEY", "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identification\": \"1012345678\",\n  \"identificationType\": \"CC\",\n  \"names\": \"Carlos Andres\",\n  \"lastNames\": \"Perez\",\n  \"email\": \"carlos.perez.admin@example.com\",\n  \"personType\": \"A\"\n}"
            },
            "url": "{{baseUrl}}/api/persons/{{personId}}"
          }
        }
      ]
    },
    {
      "name": "03 - Usuarios (Protegido)",
      "item": [
        {
          "name": "PUT Cambiar password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-API-KEY", "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"Admin1234!\"\n}"
            },
            "url": "{{baseUrl}}/api/users/{{adminLogin}}/password"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) { pm.collectionVariables.set('adminPassword', 'Admin1234!'); }"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Regenerar API key",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-API-KEY", "value": "{{apiKey}}" }
            ],
            "url": "{{baseUrl}}/api/users/{{adminLogin}}/regenerate-apikey"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "if (data && data.apiKey) { pm.collectionVariables.set('apiKey', String(data.apiKey)); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04 - Documentos (Protegido)",
      "item": [
