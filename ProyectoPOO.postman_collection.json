            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"AUTOMOVIL\",\n  \"plate\": \"ABC123\",\n  \"serviceType\": \"PR\",\n  \"fuelType\": \"GASOLINA\",\n  \"passengersCapacity\": 4,\n  \"color\": \"#112233\",\n  \"model\": 2024,\n  \"brand\": \"Toyota\",\n  \"line\": \"Corolla XLI\"\n}"
